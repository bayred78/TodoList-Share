rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 사용자 문서 =====
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      // DM: 로그인 사용자면 누구나 상대에게 메시지 전송 가능
      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // 즐겨찾기: 본인만 읽기/쓰기/삭제
      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ===== 닉네임 유니크 보장 =====
    match /nicknames/{nickname} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null 
        && resource.data.uid == request.auth.uid;
    }

    // ===== 프로젝트 =====
    match /projects/{projectId} {
      // 멤버만 읽기 가능
      allow read: if request.auth != null 
        && (request.auth.uid in resource.data.members
            || request.auth.uid in resource.data.memberUIDs);

      // 프로젝트 생성 - 로그인된 사용자
      allow create: if request.auth != null;

      // 프로젝트 수정 - 기존 멤버 또는 초대 수락으로 자신을 추가하는 사용자
      allow update: if request.auth != null 
        && (request.auth.uid in resource.data.members
            || (request.auth.uid in request.resource.data.members
                && !(request.auth.uid in resource.data.members)));

      // 프로젝트 삭제 - 관리자만
      allow delete: if request.auth != null 
        && resource.data.members[request.auth.uid].role == 'admin';

      // ===== 투두 아이템 =====
      match /items/{itemId} {
        // 읽기 - 프로젝트 멤버만
        allow read: if request.auth != null 
          && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.members;

        // 쓰기 - 권한 확인 + 구독 상태 확인
        allow create, update, delete: if request.auth != null 
          && canWriteToProject(projectId);
      }

      // ===== 채팅 메시지 =====
      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.members;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.members;
      }

      // ===== 채팅 읽음 확인 =====
      match /chatLastRead/{userId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.members;
      }
    }

    // ===== 초대 =====
    match /invitations/{invitationId} {
      // 초대한 사람 또는 초대받은 사람만 읽기
      allow read: if request.auth != null 
        && (resource.data.inviterId == request.auth.uid 
            || resource.data.inviteeId == request.auth.uid);
      
      // 초대 생성 - 로그인된 사용자
      allow create: if request.auth != null;
      
      // 초대 수정 - 초대받은 사람(수락/거절) 또는 초대한 사람(취소)
      allow update: if request.auth != null 
        && (resource.data.inviteeId == request.auth.uid
            || resource.data.inviterId == request.auth.uid);

      // 초대 삭제 - 초대한 사람만 (취소)
      allow delete: if request.auth != null
        && resource.data.inviterId == request.auth.uid;
    }

    // ===== 헬퍼 함수 =====
    function canWriteToProject(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      let isMember = request.auth.uid in project.members;
      let isWriter = isMember && project.members[request.auth.uid].role != 'viewer';
      let isReadOnly = project.memberCount >= 3 && project.subscriptionActive != true;
      return isWriter && !isReadOnly;
    }

    // ===== 공유 아이템 (스냅샷) =====
    match /sharedItems/{shareId} {
      // 누구나 읽기 가능 (비인증 포함)
      allow read: if true;
      // 생성: 로그인 사용자만
      allow create: if request.auth != null;
      // 삭제: 공유자 본인만
      allow delete: if request.auth != null
        && resource.data.sharedBy == request.auth.uid;
      // 수정 불가 (스냅샷이므로)
      allow update: if false;
    }
  }
}
